# 后端由 pydantic-settings 从此文件加载（与 frontend/.env 无关，需单独配置）
DATABASE_URL=mysql+asyncmy://root:root@localhost:3306/barevid?charset=utf8mb4

# 每账号同时存在的项目数上限（删项目释放额度）；按需改成 5、10 等；0=不限制
MAX_PROJECTS_PER_USER=1

# 新建项目「口播目标时长」上限（分钟），如 5、10；前端档位与自选分钟数不超过该值
MAX_TARGET_NARRATION_MINUTES=3

# 与你在 frontend/.env 里写的保持一致（后端不会读 frontend/.env）
STORAGE_ROOT=../storage
EXPORT_PLAY_ORIGIN=https://yourdomain.com
EXPORT_API_URL=https://yourdomain.com
EXPORT_FRONTEND_URL=https://yourdomain.com
EXPORT_PUBLIC_BASE_URL=https://yourdomain.com
EXPORT_WORKER_TOKEN=test_key
# deepseek的api key
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# deepseek的补全代码功能
DEEPSEEK_BETA_BASE_URL=https://api.deepseek.com/beta

# 豆包语音：同一后端进程内「同时在飞的」TTS 请求数上限（与控制台配额一致，常见为 10）
TTS_CONCURRENCY_LIMIT=10
DOUBAO_TTS_APP_ID=your_app_id
DOUBAO_TTS_ACCESS_TOKEN=your_access_token
DEEPSEEK_DECK_MAX_TOKENS=8192

DEEPSEEK_DECK_MAX_TOKENS=8192
DEEPSEEK_STRUCTURE_MAX_TOKENS=8192
DEEPSEEK_STYLE_MAX_TOKENS=4096