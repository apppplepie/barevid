FROM node:20-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend ./
RUN npm run build

FROM node:20-alpine

WORKDIR /app
ENV NODE_ENV=production

COPY frontend/package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY frontend/server.js ./server.js

EXPOSE 3000

CMD ["node", "server.js"]
