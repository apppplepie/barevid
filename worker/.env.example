# 复制为同目录下的 `.env` 后修改（勿提交真实密钥）
SLIDEFORGE_API_URL=https://yourdomain.com
SLIDEFORGE_FRONTEND_URL=https://yourdomain.com

# 须与后端 .env 里 EXPORT_WORKER_TOKEN 相同
SLIDEFORGE_WORKER_KEY=test_key
SLIDEFORGE_WORKER_ID=user_id

# worker_export_video.py：单实例单并发，避免同机同时起多套浏览器+ffmpeg
SLIDEFORGE_WORKER_CONCURRENCY=1
# 队列空时多久再拉一次任务（秒）
SLIDEFORGE_WORKER_POLL_SECONDS=3

# 子进程 export_video.py 会继承下列可选变量
# FFmpeg 解码 VP8 时内存不足(Cannot allocate memory)时可试：SLIDEFORGE_FFMPEG_THREADS=1
# SLIDEFORGE_FFMPEG_THREADS=1
# SLIDEFORGE_EXPORT_EXTRA_WAIT_MS=1200
# 单个导出任务超时秒数，0 或留空表示不限制
# SLIDEFORGE_EXPORT_JOB_TIMEOUT_SECONDS=3600