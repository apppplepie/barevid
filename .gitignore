**/.env.*
!**/.env.example

# 本机/服务器上的 nginx 等配置（含域名与反代，勿入库）
worker/test.conf

# TLS 私钥类（若放在仓库旁）
*.pem
*.key

# Nested repo backup (see repo setup notes)
.slideforge-git-backup/

# Worker local SQLite (export history)
worker/worker_tasks.db
worker/worker_tasks.db-wal
worker/worker_tasks.db-shm

# Python
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
*.egg-info/
.eggs/

# barevidweb: 演示用视频体积大，勿提交（本地或 CDN；GitHub clone 更轻）
barevidweb/public/vidsrc/*.mp4

# Node / frontend build
**/node_modules/
**/dist/

# IDE / OS
.idea/
.vscode/

# Claude Code: local permissions + git worktrees for parallel sessions (large duplicate trees)
.claude/
.DS_Store
Thumbs.db
