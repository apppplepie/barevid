# Secrets
.env
**/.env
**/.env.local
# 其它环境文件（保留 *example* 供提交）
**/.env.*
!**/.env.example

# 本机/服务器上的 nginx 等配置（含域名与反代，勿入库）
nginx.conf
worker/test.conf

# TLS 私钥类（若放在仓库旁）
*.pem
*.key

# Nested repo backup (see repo setup notes)
.slideforge-git-backup/

# PowerShell worker 日志（本机调试用）
ps_worker_err.txt
ps_worker_out.txt

# 本地脚本（含 Docker 一键构建等，不入库）
scripts/

# Worker local SQLite (export history)
worker/worker_tasks.db
worker/worker_tasks.db-wal
worker/worker_tasks.db-shm

# Python
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
*.egg-info/
.eggs/

# barevidweb: 演示用视频体积大，勿提交（本地或 CDN；GitHub clone 更轻）
barevidweb/public/vidsrc/*.mp4

# README 演示：mp4 易超 GitHub 100MB 上限；gif 可入库（仍建议 <50MB）
docs/demo/*.mp4

# Node / frontend build
**/node_modules/
**/dist/

# IDE / OS
.idea/
.vscode/

# Claude Code: local permissions + git worktrees for parallel sessions (large duplicate trees)
.claude/
.DS_Store
Thumbs.db
